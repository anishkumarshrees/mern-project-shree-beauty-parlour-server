{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "sourceMap": true,

    "skipLibCheck": true
  },
  "include": ["server.ts", "src/**/*.ts"]
}